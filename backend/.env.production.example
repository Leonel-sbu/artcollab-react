# =============================================================================
# ARTCOLLAB PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your production values
# DO NOT commit this file to version control!
# =============================================================================

# Server Configuration
PORT=5000
NODE_ENV=production

# =============================================================================
# DATABASE - MONGODB ATLAS
# =============================================================================
# Get your connection string from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com/
# 2. Select your cluster
# 3. Click "Connect" > "Drivers"
# 4. Copy the connection string
#
# Format: mongodb+srv://<username>:<password>@cluster<number>.xxx.mongodb.net/artcollab?appName=Cluster0&retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string_here

# =============================================================================
# JWT SECRET - CRITICAL SECURITY
# =============================================================================
# Generate a strong random secret:
# - Use at least 32 characters
# - Use a mix of letters, numbers, and special characters
# - Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_jwt_secret_here

# =============================================================================
# CLIENT URL - Your production frontend domain
# =============================================================================
CLIENT_URL=https://your-production-domain.com

# =============================================================================
# STRIPE PAYMENT PROCESSING
# =============================================================================
# Get your keys from: https:nnur_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# EMAIL / SENDGRID (Optional - for password reset, notifications)
# =============================================================================
# Get credentials from: https://sendgrid.com/
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# ADMIN CREDENTIALS - Create after deployment
# =============================================================================
# Set these via environment variables, not in this file!
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your_secure_admin_password

# =============================================================================
# RATE LIMITING (Optional - advanced)
# =============================================================================
# REDIS_URL=redis://localhost:6379  # For distributed rate limiting
