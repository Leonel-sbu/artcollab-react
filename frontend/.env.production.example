# =============================================================================
# ARTCOLLAB FRONTEND PRODUCTION ENVIRONMENT
# =============================================================================
# Copy this file to .env and fill in your production values
# DO NOT commit this file to version control!
# =============================================================================

# API Base URL - Your production backend URL
VITE_API_BASE_URL=https://api.your-production-domain.com

# =============================================================================
# STRIPE PUBLIC KEY
# =============================================================================
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# Use the LIVE key (starts with pk_live_) for production
VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_publishable_key
